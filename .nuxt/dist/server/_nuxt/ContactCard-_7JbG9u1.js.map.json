n      {{ email }}\n    </a>\n\n    <div class=\"mt-2 flex flex-wrap gap-4\">\n      <a\n        v-for=\"link in links\"\n        :key=\"link.url\"\n        :href=\"link.url\"\n        target=\"_blank\"\n        rel=\"noopener\"\n        class=\"text-sm text-text-muted transition-colors duration-150 hover:text-text\"\n      >\n        {{ link.name }}\n      </a>\n    </div>\n  </div>\n</template>"],"version":3}