else
  export NODE_PATH="/Users/drupalio/drupalio.dev/node_modules/.pnpm/@eslint+config-inspector@3.0.4_crossws@0.4.9_srvx@0.11.21__esbuild@0.28.1_eslint@9.39.4_72f464e1af502cb222a9c0a56568e40d/node_modules/@eslint/config-inspector/node_modules:/Users/drupalio/drupalio.dev/node_modules/.pnpm/@eslint+config-inspector@3.0.4_crossws@0.4.9_srvx@0.11.21__esbuild@0.28.1_eslint@9.39.4_72f464e1af502cb222a9c0a56568e40d/node_modules:/Users/drupalio/drupalio.dev/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -n "$exe" ] && [ -x "$basedir/node.exe" ]; then
  exec "$basedir/node.exe"  "$basedir_win/../@eslint/config-inspector/bin.mjs" "$@"
elif [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../@eslint/config-inspector/bin.mjs" "$@"
elif command -v node >/dev/null 2>&1; then
  exec node  "$basedir/../@eslint/config-inspector/bin.mjs" "$@"
elif [ -n "$exe" ] && command -v node.exe >/dev/null 2>&1; then
